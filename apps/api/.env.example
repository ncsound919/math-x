# ── Claude (default cloud provider) ────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4000

# ── Ollama local inference (DeepSeek-R1) ───────────────────────────
# Run: ollama pull deepseek-r1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b

# ── Qwen2.5-Math (specialized symbolic math) ───────────────────────
# Run: ollama pull qwen2.5-math:7b
QWEN_BASE_URL=http://localhost:11434
QWEN_MODEL=qwen2.5-math:7b

# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
